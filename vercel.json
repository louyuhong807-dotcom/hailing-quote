{
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/xhs-monitor",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/xhs-monitor-data.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/douyin-monitor-data.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
